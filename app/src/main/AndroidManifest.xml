<?xml version="1.0" encoding="utf-8"?>
<!--
    Android manifest for Still.

    Important privacy notes:
    - There is intentionally no INTERNET permission.
    - There is intentionally no QUERY_ALL_PACKAGES permission.
    - The <queries> block scopes PackageManager visibility to launchable apps only.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        Allows PackageManager queries for apps that expose normal launchable activities, plus a
        narrow set of category intents we resolve once on first launch to seed default home
        slots (DefaultSlotResolver). Each <intent> element only widens visibility to apps that
        match that exact intent — no broad QUERY_ALL_PACKAGES.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.DIAL" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_MESSAGING" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_BROWSER" />
        </intent>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_CALENDAR" />
        </intent>
        <intent>
            <action android:name="android.settings.SETTINGS" />
        </intent>
    </queries>

    <application
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@drawable/ic_still_launcher"
        android:roundIcon="@drawable/ic_still_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Still"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".MainActivity"
            android:exported="true">

            <!-- Required for Android to offer Still as a selectable default Home app. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <!-- Optional: lets the user open Still before setting it as the default Home app. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
